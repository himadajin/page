---
import type { OutlineSection } from "@/utils/outline";

type Props = {
  title: string;
  sections: OutlineSection[];
};

const { title, sections } = Astro.props;
const shouldShowReadingMap = sections.length >= 2;
---

{
  shouldShowReadingMap && (
    <aside class="reading-map" aria-label="Reading map" data-reading-map>
      <div class="reading-map__meta">
        <p class="reading-map__eyebrow">Sections</p>
        <p class="reading-map__title">{title}</p>
      </div>
      <nav class="reading-map__nav" aria-label="Page sections">
        <a class="reading-map__top" href="#main-content">
          Top
        </a>
        <ol class="reading-map__list">
          {sections.map(section => (
            <li class="reading-map__item" data-reading-map-section={section.id}>
              <a class="reading-map__link" href={`#${section.id}`}>
                {section.text}
              </a>
              {section.children.length > 0 && (
                <ol class="reading-map__children">
                  {section.children.map(child => (
                    <li>
                      <a class="reading-map__child-link" href={`#${child.id}`}>
                        {child.text}
                      </a>
                    </li>
                  ))}
                </ol>
              )}
            </li>
          ))}
        </ol>
      </nav>
    </aside>
  )
}

<style>
  .reading-map {
    position: fixed;
    inset-block-start: 7.5rem;
    inset-inline-start: max(1rem, calc(50% - 36rem));
    z-index: 20;
    display: none;
    width: 12rem;
    max-height: calc(100svh - 9rem);
    overflow-y: auto;
    padding-inline-start: 0.75rem;
    border-inline-start: 1px solid var(--border);
    background: color-mix(in srgb, var(--background) 92%, transparent);
    backdrop-filter: blur(10px);
    scrollbar-width: thin;
  }

  .reading-map__meta {
    margin-block-end: 0.75rem;
  }

  .reading-map__eyebrow {
    margin: 0;
    color: color-mix(in srgb, var(--foreground) 48%, transparent);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .reading-map__title {
    display: -webkit-box;
    margin: 0.25rem 0 0;
    overflow: hidden;
    color: var(--foreground);
    font-size: 0.75rem;
    font-weight: 700;
    line-height: 1.4;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .reading-map__nav {
    font-size: 0.8125rem;
    line-height: 1.35;
  }

  .reading-map__top,
  .reading-map__link,
  .reading-map__child-link {
    display: block;
    border-radius: 0.25rem;
    text-decoration: none;
  }

  .reading-map__top {
    margin-block-end: 0.375rem;
    padding: 0.25rem 0.375rem;
    color: color-mix(in srgb, var(--foreground) 58%, transparent);
    font-weight: 700;
  }

  .reading-map__list,
  .reading-map__children {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .reading-map__item {
    position: relative;
    margin-block: 0.125rem;
  }

  .reading-map__item::before {
    position: absolute;
    inset-block: 0.3rem;
    inset-inline-start: -0.75rem;
    width: 1px;
    background: transparent;
    content: "";
  }

  .reading-map__link {
    display: -webkit-box;
    overflow: hidden;
    padding: 0.25rem 0.375rem;
    color: color-mix(in srgb, var(--foreground) 52%, transparent);
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .reading-map__children {
    display: none;
    padding-block: 0.125rem 0.25rem;
    padding-inline-start: 0.625rem;
  }

  .reading-map__child-link {
    padding: 0.1875rem 0.375rem;
    color: color-mix(in srgb, var(--foreground) 58%, transparent);
    font-size: 0.75rem;
  }

  .reading-map__top:hover,
  .reading-map__link:hover,
  .reading-map__child-link:hover {
    color: var(--accent);
  }

  .reading-map__item.is-active::before {
    background: var(--accent);
  }

  .reading-map__item.is-active > .reading-map__link {
    color: var(--foreground);
    font-weight: 700;
  }

  .reading-map__item.is-active > .reading-map__children {
    display: block;
  }

  @media (min-width: 1180px) {
    .reading-map {
      display: block;
    }
  }
</style>

<script>
  function setupReadingMap() {
    const mapWindow = window as Window & {
      __readingMapAbortController?: AbortController;
    };

    mapWindow.__readingMapAbortController?.abort();

    const controller = new AbortController();
    mapWindow.__readingMapAbortController = controller;
    const { signal } = controller;

    const root = document.querySelector<HTMLElement>("[data-reading-map]");
    if (!root) return;

    const mapRoot = root;

    const sectionItems = Array.from(
      mapRoot.querySelectorAll("[data-reading-map-section]")
    );
    const sectionHeadings = sectionItems
      .map(item => {
        const id = item.getAttribute("data-reading-map-section");
        const heading = id ? document.getElementById(id) : null;
        return heading ? { id, heading } : null;
      })
      .filter(
        (item): item is { id: string; heading: HTMLElement } => item !== null
      );

    let activeId = "";
    let ticking = false;

    function scrollItemIntoMap(item: Element) {
      if (getComputedStyle(mapRoot).display === "none") return;

      const itemRect = item.getBoundingClientRect();
      const rootRect = mapRoot.getBoundingClientRect();
      const itemTop = itemRect.top - rootRect.top + mapRoot.scrollTop;
      const itemBottom = itemTop + itemRect.height;
      const padding = 24;

      if (itemTop < mapRoot.scrollTop + padding) {
        mapRoot.scrollTop = Math.max(0, itemTop - padding);
      } else if (
        itemBottom >
        mapRoot.scrollTop + mapRoot.clientHeight - padding
      ) {
        mapRoot.scrollTop = itemBottom - mapRoot.clientHeight + padding;
      }
    }

    function setActive(id: string) {
      if (!id || activeId === id) return;
      activeId = id;

      for (const item of sectionItems) {
        const isActive = item.getAttribute("data-reading-map-section") === id;
        item.classList.toggle("is-active", isActive);

        const link = item.querySelector(".reading-map__link");
        if (link) {
          if (isActive) {
            link.setAttribute("aria-current", "location");
          } else {
            link.removeAttribute("aria-current");
          }
        }

        if (isActive) {
          scrollItemIntoMap(item);
        }
      }
    }

    function findActiveHeading() {
      ticking = false;
      const offset = 140;
      let nextActiveId = sectionHeadings[0]?.id || "";

      for (const item of sectionHeadings) {
        const top = item.heading.getBoundingClientRect().top;
        if (top <= offset) {
          nextActiveId = item.id;
        } else {
          break;
        }
      }

      setActive(nextActiveId);
    }

    function requestUpdate() {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(findActiveHeading);
    }

    document.addEventListener("scroll", requestUpdate, {
      passive: true,
      signal,
    });
    window.addEventListener("resize", requestUpdate, { signal });

    if ("IntersectionObserver" in window) {
      const observer = new IntersectionObserver(() => requestUpdate(), {
        rootMargin: "-20% 0px -70% 0px",
        threshold: 0,
      });

      for (const item of sectionHeadings) {
        observer.observe(item.heading);
      }

      signal.addEventListener("abort", () => observer.disconnect(), {
        once: true,
      });
    }

    findActiveHeading();
  }

  setupReadingMap();

  // Runs on view transitions navigation
  document.addEventListener("astro:after-swap", setupReadingMap);
</script>
