---
import { SECTIONS } from "@/config";

// Remove current url path and remove trailing slash if exists
const currentUrlPath = Astro.url.pathname.replace(/\/+$/, "");

// Get url array from path
// eg: /tags/tailwindcss => ['tags', 'tailwindcss']
const breadcrumbList = currentUrlPath.split("/").slice(1);

const STATIC_LABELS: Record<string, string> = {
  tags: "Tags",
  search: "Search",
};

const getBreadcrumbLabel = (breadcrumb: string) =>
  SECTIONS.find(section => section.path === `/${breadcrumb}`)?.label ??
  STATIC_LABELS[breadcrumb] ??
  breadcrumb;
---

<nav class="app-layout mt-6 mb-2" aria-label="breadcrumb">
  <ul
    class="flex flex-wrap items-center text-sm leading-5 font-normal text-foreground/65"
  >
    <li>
      <a href="/" class="text-foreground/70 hover:text-accent">Home</a>
      <span aria-hidden="true" class="mx-2 text-foreground/35">&raquo;</span>
    </li>
    {
      breadcrumbList.map((breadcrumb, index) =>
        index + 1 === breadcrumbList.length ? (
          <li>
            <span
              class:list={[
                "text-foreground/60 capitalize",
                { lowercase: index > 0 },
              ]}
              aria-current="page"
            >
              {/* make the last part lowercase in Home > Tags > some-tag */}
              {decodeURIComponent(getBreadcrumbLabel(breadcrumb))}
            </span>
          </li>
        ) : (
          <li>
            <a
              href={`/${breadcrumbList.slice(0, index + 1).join("/")}/`}
              class="text-foreground/70 capitalize hover:text-accent"
            >
              {getBreadcrumbLabel(breadcrumb)}
            </a>
            <span aria-hidden="true" class="mx-2 text-foreground/35">
              &raquo;
            </span>
          </li>
        )
      )
    }
  </ul>
</nav>
