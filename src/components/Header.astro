---
import IconX from "@/assets/icons/IconX.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import LinkButton from "./LinkButton.astro";
import { SECTIONS, SITE } from "@/config";
import type { OutlineSection } from "@/utils/outline";

type Props = {
  outlineTitle?: string;
  outlineSections?: OutlineSection[];
};

const { outlineTitle, outlineSections = [] } = Astro.props;
const hasOutline = outlineSections.length >= 2;
const { pathname } = Astro.url;

// Remove trailing slash from current pathname if exists
const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());

  return currentPath === path || currentPathArray[0] === pathArray[0];
};

const browseLinks = [
  ...SECTIONS.map(section => ({
    label: section.label,
    path: section.path,
    active: isActive(section.path),
  })),
  { label: "Tags", path: "/tags", active: isActive("/tags") },
  { label: "Search", path: "/search", active: isActive("/search") },
];
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 bg-background px-3 py-2 text-accent backdrop-blur-lg transition-all focus:top-4"
>
  Skip to content
</a>

<header
  class="app-layout flex flex-col items-center justify-between sm:flex-row"
>
  <div
    id="top-nav-wrap"
    class:list={[
      "py-4 sm:py-6",
      "border-b border-border",
      "relative w-full bg-background",
      "flex items-baseline justify-between sm:items-center",
    ]}
  >
    <a
      href="/"
      class="absolute py-1 text-xl leading-8 font-semibold whitespace-nowrap sm:static sm:my-auto sm:text-2xl sm:leading-none"
    >
      {SITE.title}
    </a>
    <nav
      id="nav-menu"
      class="flex w-full flex-col items-center sm:ms-2 sm:flex-row sm:justify-end sm:space-x-4 sm:py-0"
      aria-label="Site"
    >
      <button
        id="menu-btn"
        class="focus-outline fixed top-4 right-4 z-[80] inline-flex items-center gap-2 border border-border bg-background/95 px-3 py-2 text-sm leading-none font-semibold shadow-[0_0.5rem_1.5rem_rgb(40_39_40_/_10%)] backdrop-blur sm:hidden"
        aria-label="Open Menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span>Menu</span>
        <IconX id="close-icon" class="hidden size-4" />
        <IconMenuDeep id="menu-icon" class="size-4" />
      </button>

      <ul
        class="hidden sm:mt-0 sm:flex sm:w-auto sm:gap-x-5 sm:gap-y-0"
        aria-label="Browse"
      >
        {
          SECTIONS.map(section => (
            <li>
              <a
                href={section.path}
                class:list={{ "active-nav": isActive(section.path) }}
              >
                {section.label}
              </a>
            </li>
          ))
        }
        <li>
          <a href="/tags" class:list={{ "active-nav": isActive("/tags") }}>
            Tags
          </a>
        </li>
        <li>
          <LinkButton
            href="/search"
            class:list={[
              "focus-outline flex p-1",
              { "[&>svg]:stroke-accent": isActive("/search") },
            ]}
            title="Search"
            aria-label="search"
          >
            <IconSearch />
            <span class="sr-only">Search</span>
          </LinkButton>
        </li>
      </ul>
    </nav>
  </div>
</header>

<div
  id="mobile-menu"
  class="fixed inset-x-4 top-16 z-[70] max-h-[calc(100svh-5rem)] overflow-y-auto border border-border bg-background/95 px-4 py-4 shadow-[0_1rem_2.5rem_rgb(40_39_40_/_12%)] backdrop-blur-md sm:hidden"
  hidden
>
  {
    hasOutline && (
      <div class="mobile-menu__sections" data-menu-outline>
        <p class="mobile-menu__title">{outlineTitle}</p>
        <p class="mobile-menu__label">Sections</p>
        <nav aria-label="Page sections">
          <a class="mobile-menu__top" href="#main-content">
            Top
          </a>
          <ol class="mobile-menu__section-list">
            {outlineSections.map(section => (
              <li
                class="mobile-menu__section-item"
                data-menu-section={section.id}
              >
                <a class="mobile-menu__section-link" href={`#${section.id}`}>
                  {section.text}
                </a>
              </li>
            ))}
          </ol>
        </nav>
      </div>
    )
  }

  <div class:list={["mobile-menu__browse", { "mt-6": hasOutline }]}>
    <p class="mobile-menu__label">Browse</p>
    <nav aria-label="Browse">
      <ul class="mobile-menu__browse-list">
        {
          browseLinks.map(link => (
            <li>
              <a
                href={link.path}
                class:list={[
                  "mobile-menu__browse-link",
                  { "is-active": link.active },
                ]}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</div>

<style>
  .mobile-menu__title {
    margin: 0 0 0.75rem;
    overflow: hidden;
    color: var(--foreground);
    font-size: 0.875rem;
    font-weight: 700;
    line-height: 1.35;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .mobile-menu__label {
    margin: 0 0 0.5rem;
    color: color-mix(in srgb, var(--foreground) 46%, transparent);
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .mobile-menu__top,
  .mobile-menu__section-link {
    display: block;
    text-decoration: none;
  }

  .mobile-menu__top {
    margin-inline-start: 0.75rem;
    padding: 0.375rem 0.625rem;
    color: color-mix(in srgb, var(--foreground) 58%, transparent);
    font-size: 0.875rem;
    font-weight: 700;
  }

  .mobile-menu__section-list {
    margin: 0.25rem 0 0;
    padding: 0;
    border-inline-start: 1px solid var(--border);
    list-style: none;
  }

  .mobile-menu__section-item {
    position: relative;
  }

  .mobile-menu__section-item::before {
    position: absolute;
    inset-block: 0.45rem;
    inset-inline-start: -1px;
    width: 1px;
    background: transparent;
    content: "";
  }

  .mobile-menu__section-link {
    padding: 0.4375rem 0.625rem 0.4375rem 0.75rem;
    color: color-mix(in srgb, var(--foreground) 58%, transparent);
    font-size: 0.9375rem;
    line-height: 1.35;
  }

  .mobile-menu__section-item.is-active::before {
    background: var(--accent);
  }

  .mobile-menu__section-item.is-active > .mobile-menu__section-link {
    color: var(--foreground);
    font-weight: 700;
  }

  .mobile-menu__browse-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.25rem 1rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .mobile-menu__browse-link {
    display: block;
    padding-block: 0.375rem;
    color: color-mix(in srgb, var(--foreground) 70%, transparent);
    font-size: 0.875rem;
    font-weight: 700;
    text-decoration: none;
  }

  .mobile-menu__browse-link.is-active {
    color: var(--foreground);
    text-decoration-line: underline;
    text-decoration-color: color-mix(
      in srgb,
      var(--foreground) 35%,
      transparent
    );
    text-decoration-style: wavy;
    text-decoration-thickness: 2px;
    text-underline-offset: 0.35rem;
  }

  .mobile-menu__top:hover,
  .mobile-menu__section-link:hover,
  .mobile-menu__browse-link:hover {
    color: var(--accent);
  }
</style>

<script>
  function setupNav() {
    const navWindow = window as Window & {
      __headerNavAbortController?: AbortController;
    };

    navWindow.__headerNavAbortController?.abort();

    const controller = new AbortController();
    navWindow.__headerNavAbortController = controller;
    const { signal } = controller;

    const menuBtn = document.querySelector<HTMLButtonElement>("#menu-btn");
    const mobileMenu = document.querySelector<HTMLElement>("#mobile-menu");
    const menuIcon = document.querySelector<SVGElement>("#menu-icon");
    const closeIcon = document.querySelector<SVGElement>("#close-icon");

    if (!menuBtn || !mobileMenu || !menuIcon || !closeIcon) return;

    const navButton = menuBtn;
    const menuPanel = mobileMenu;
    const openIcon = menuIcon;
    const shutIcon = closeIcon;

    const sectionItems = Array.from(
      menuPanel.querySelectorAll("[data-menu-section]")
    );
    const sectionHeadings = sectionItems
      .map(item => {
        const id = item.getAttribute("data-menu-section");
        const heading = id ? document.getElementById(id) : null;
        return heading ? { id, heading } : null;
      })
      .filter(
        (item): item is { id: string; heading: HTMLElement } => item !== null
      );

    let activeId = "";
    let ticking = false;

    function setMenuOpen(open: boolean) {
      navButton.setAttribute("aria-expanded", open ? "true" : "false");
      navButton.setAttribute("aria-label", open ? "Close Menu" : "Open Menu");
      menuPanel.hidden = !open;
      openIcon.classList.toggle("hidden", open);
      shutIcon.classList.toggle("hidden", !open);

      if (open) {
        updateActiveSection();
      }
    }

    function setActive(id: string) {
      if (!id || activeId === id) return;
      activeId = id;

      for (const item of sectionItems) {
        const isActive = item.getAttribute("data-menu-section") === id;
        item.classList.toggle("is-active", isActive);

        const link = item.querySelector(".mobile-menu__section-link");
        if (link) {
          if (isActive) {
            link.setAttribute("aria-current", "location");
          } else {
            link.removeAttribute("aria-current");
          }
        }
      }
    }

    function updateActiveSection() {
      ticking = false;
      const offset = 140;
      let nextActiveId = sectionHeadings[0]?.id || "";

      for (const item of sectionHeadings) {
        const top = item.heading.getBoundingClientRect().top;
        if (top <= offset) {
          nextActiveId = item.id;
        } else {
          break;
        }
      }

      setActive(nextActiveId);
    }

    function requestUpdate() {
      if (ticking || sectionHeadings.length === 0) return;
      ticking = true;
      window.requestAnimationFrame(updateActiveSection);
    }

    navButton.addEventListener(
      "click",
      () => {
        const isOpen = navButton.getAttribute("aria-expanded") === "true";
        setMenuOpen(!isOpen);
      },
      { signal }
    );

    menuPanel.addEventListener(
      "click",
      event => {
        const target = event.target;
        if (target instanceof Element && target.closest("a[href]")) {
          setMenuOpen(false);
        }
      },
      { signal }
    );

    document.addEventListener("scroll", requestUpdate, {
      passive: true,
      signal,
    });
    window.addEventListener("resize", requestUpdate, { signal });

    updateActiveSection();
  }

  setupNav();

  // Runs on view transitions navigation
  document.addEventListener("astro:after-swap", setupNav);
</script>
