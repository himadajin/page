---
import { render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Tag from "@/components/Tag.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import CodeBlockCopy from "@/components/CodeBlockCopy.astro";
import HeadingLinks from "@/components/HeadingLinks.astro";
import ReadingMap from "@/components/ReadingMap.astro";
import { getOutlineSections, shouldShowOutline } from "@/utils/outline";
import type { ReferenceItem } from "@/utils/references";
import { slugifyStr } from "@/utils/slugify";
import { SITE } from "@/config";

type Props = ReferenceItem;

const { entry, href } = Astro.props;

const { title, description, ogImage: initOgImage, tags } = entry.data;

const { Content, headings } = await render(entry);
const outlineSections = getOutlineSections(headings);
const hasOutline = shouldShowOutline(outlineSections);

let ogImageUrl: string | undefined;

if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage;
} else if (initOgImage?.src) {
  ogImageUrl = initOgImage.src;
}

if (!ogImageUrl && SITE.dynamicOgImage) {
  ogImageUrl = `${href}/index.png`;
}

const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.url.origin).href
  : undefined;

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  description,
  ogImage,
};
---

<Layout {...layoutProps}>
  <Header
    outlineTitle={hasOutline ? title : undefined}
    outlineSections={hasOutline ? outlineSections : []}
  />
  <Breadcrumb />
  <main id="main-content" class="app-layout pb-12" data-pagefind-body>
    <h1
      transition:name={slugifyStr(title.replaceAll(".", "-"))}
      class="inline-block text-2xl font-bold text-accent sm:text-3xl"
    >
      {title}
    </h1>
    <article
      id="article"
      class="app-prose mt-8 w-full max-w-app prose-pre:bg-(--shiki-light-bg)"
    >
      <Content />
    </article>

    <hr class="my-8 border-dashed" />

    {
      tags.length > 0 && (
        <ul class="mt-4 mb-8 flex flex-wrap gap-4 sm:my-8">
          {tags.map(tag => (
            <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" />
          ))}
        </ul>
      )
    }
  </main>
  <ReadingMap title={title} sections={hasOutline ? outlineSections : []} />
  <CodeBlockCopy />
  <HeadingLinks />
  <Footer />
</Layout>
