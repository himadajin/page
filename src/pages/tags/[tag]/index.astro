---
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import ReferenceCard from "@/components/ReferenceCard.astro";
import getUniqueTags from "@/utils/getUniqueTags";
import { getReferenceItems, type ReferenceItem } from "@/utils/references";
import { slugifyAll } from "@/utils/slugify";
import { SITE } from "@/config";

export async function getStaticPaths() {
  const items = await getReferenceItems();
  const tags = getUniqueTags(items);

  return tags.map(({ tag, tagName }) => ({
    params: { tag },
    props: {
      tagName,
      items: items.filter(item =>
        slugifyAll(item.entry.data.tags).includes(tag)
      ),
    },
  }));
}

const { tag } = Astro.params;
const { items, tagName } = Astro.props as {
  items: ReferenceItem[];
  tagName: string;
};
---

<Layout title={`Tag: ${tagName} | ${SITE.title}`}>
  <Header />
  <Main
    pageTitle={[`Tag:`, `${tagName}`]}
    titleTransition={tag ?? tagName}
    pageDesc={`タグ "${tagName}" が付いた資料です。`}
  >
    <h1 slot="title" transition:name={tag}>{`Tag:${tag}`}</h1>
    <ul>
      {items.map(item => <ReferenceCard {...item} />)}
    </ul>
  </Main>

  <Footer />
</Layout>
