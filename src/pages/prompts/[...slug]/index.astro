---
import { getCollection, type CollectionEntry } from "astro:content";
import ReferenceDetails from "@/layouts/ReferenceDetails.astro";
import {
  getReferencePath,
  isIndexEntry,
  toReferenceItem,
} from "@/utils/references";

type Props = {
  entry: CollectionEntry<"prompts">;
};

export async function getStaticPaths() {
  const entries = await getCollection("prompts");

  return entries
    .filter(entry => !isIndexEntry(entry))
    .map(entry => ({
      params: { slug: getReferencePath("prompts", entry.id, false) },
      props: { entry },
    }));
}

const { entry } = Astro.props;
const item = toReferenceItem("prompts", entry);
---

<ReferenceDetails {...item} />
